node_modules/
.astro/
.claude/
!.claude/commands/
!.claude/commands/**
!.claude/orchestration-SOMA-node/
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# User-created org data (not part of the framework)
orgs/
# But community subdirectories ARE part of the framework
!community/
!community/**

# Secrets
.env
!.env.example
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
# Use `docs/*` instead of `docs/` so git can honor the !docs/handoffs
# exception below — gitignore can re-include children of an ignored
# directory only if the directory itself isn't fully excluded.
docs/*
# ...except SOMA handoff snapshots — part of the public project record.
!docs/handoffs/
!docs/handoffs/**
# ...and the SOMA wiki — concept/setup/architecture docs for the public repo.
!docs/wiki/
!docs/wiki/**

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
dashboard/screenshots/
dashboard/test-*.py
